# === Threads Graph API (required) ===
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# === Backblaze B2 (required) ===
B2_BUCKET=12amstories
B2_KEY_ID=
B2_APPLICATION_KEY=
# Folder inside the bucket where the images live (include trailing slash)
B2_PREFIX=threads/

# === Host directory containing quotes.json (required by docker-compose) ===
# This is the absolute path ON THE VPS to a DIRECTORY (not a file) that
# contains quotes.json. The directory is bind-mounted at /data inside the
# container. Must be writable by uid 10001:
#   mkdir -p /home/ubuntu/threads-api-posting/data
#   sudo chown -R 10001:10001 /home/ubuntu/threads-api-posting/data
QUOTES_HOST_DIR=/home/ubuntu/threads-api-posting/data

# === Tuning (optional — defaults shown) ===
# Seconds to wait between creating and publishing the media container
THREADS_MEDIA_WAIT_SECONDS=30
# Presigned URL lifetime in seconds
THREADS_PRESIGN_EXPIRATION_SECONDS=900

# === Telegram notifications (optional) ===
# Leave blank to disable notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Note: do NOT set QUOTES_JSON_PATH, LOCKFILE_PATH, or TZ here —
# docker-compose.yml sets those for the container.
